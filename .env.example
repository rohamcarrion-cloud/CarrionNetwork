# ─────────────────────────────────────────────────────────────
# Carrion Networks — environment template
# Copy this file to `.env` and adjust values for your machine:
#   cp .env.example .env
# No real secrets are committed here.
# ─────────────────────────────────────────────────────────────

# PocketBase Configuration
# The base URL the frontend uses to reach PocketBase.
VITE_POCKETBASE_URL=http://localhost:8090

# Optional: PocketBase encryption key.
# ONLY needed if you are booting an EXISTING encrypted pb_data directory
# (e.g. one exported from Horizon). For a clean local setup you do NOT need
# this — delete pb_data and let PocketBase create a fresh, unencrypted DB.
# POCKETBASE_ENCRYPTION_KEY=your-key-here

# Frontend Configuration
VITE_APP_NAME=Carrion Networks
VITE_APP_URL=http://localhost:3000
